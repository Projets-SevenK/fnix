# =========================================================
# FNIX — Variables d'environnement locales
# Copier ce fichier en .env.local puis remplir les valeurs.
# Ne jamais commit .env.local.
# =========================================================

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=FNIX

# Supabase — côté client, valeurs publiques contrôlées par les règles RLS
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — côté serveur uniquement
# Ne jamais exposer cette clé dans un composant client.
SUPABASE_SERVICE_ROLE_KEY=

# Admin
ADMIN_EMAIL=

# Produit FNIX
FNIX_PRODUCT_NAME=T-shirt FNIX Drop 044
FNIX_PRODUCT_SIZE=M
FNIX_INITIAL_STOCK=7
FNIX_DROP_NUMBER=044
FNIX_PRODUCT_PRICE=
FNIX_SHIPPING_PRICE=

# Wero — paiement manuel
FNIX_WERO_PHONE=
FNIX_WERO_EMAIL=
FNIX_WERO_QR_CODE_URL=

# Notifications email, optionnel pour V1
RESEND_API_KEY=
ORDER_NOTIFICATION_EMAIL=

# Réseaux sociaux
NEXT_PUBLIC_INSTAGRAM_URL=
